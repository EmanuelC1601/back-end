# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# CONFIGURACIÓN DE MYSQL
# (REEMPLAZAR CON TUS DATOS REALES)
# ============================================
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================
JWT_SECRET=your_jwt_secret_min_32_chars
SESSION_SECRET=your_session_secret_min_32_chars

# ============================================
# GOOGLE RECAPTCHA
# ============================================
RECAPTCHA_SITE_KEY=6Lehh5YsAAAAAHU_9fdBCtxTxEKpNryNt0kopRp-
RECAPTCHA_SECRET_KEY=6Lehh5YsAAAAALC4wBwdatLpSZNVgjq_BTtHyTg6

# ============================================
# LÍMITES DE LA APLICACIÓN
# ============================================
MAX_FILE_SIZE=5242880
MAX_FILES=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml

# ============================================
# RENDER (OPCIONAL)
# ============================================
RENDER=true
RENDER_EXTERNAL_URL=https://your-backend.onrender.com